{
  "status": {
    "light": {
      "positive": { "$type": "color", "$value": "#087a5b" },
      "positive-subtle": { "$type": "color", "$value": "#e6f6ef" },
      "warning": { "$type": "color", "$value": "#9a5b08" },
      "warning-subtle": { "$type": "color", "$value": "#fff4df" },
      "critical": { "$type": "color", "$value": "#b9364f" },
      "critical-subtle": { "$type": "color", "$value": "#fcedef" },
      "info": { "$type": "color", "$value": "#2b65b1" },
      "info-subtle": { "$type": "color", "$value": "#eaf2fc" }
    },
    "dark": {
      "positive": { "$type": "color", "$value": "#6dd6ad" },
      "positive-subtle": { "$type": "color", "$value": "#17382e" },
      "warning": { "$type": "color", "$value": "#f2bd6c" },
      "warning-subtle": { "$type": "color", "$value": "#423116" },
      "critical": { "$type": "color", "$value": "#ff8fa2" },
      "critical-subtle": { "$type": "color", "$value": "#4a2028" },
      "info": { "$type": "color", "$value": "#8db8f4" },
      "info-subtle": { "$type": "color", "$value": "#1a2d42" }
    }
  },
  "chart": {
    "$description": "Shared chart defaults — var()-derived so they adapt to every brand/mode; apps may override per-brand (finance tunes grid/axis in app.css).",
    "grid": {
      "$type": "cssValue",
      "$value": "color-mix(in srgb, var(--t3, var(--text-muted)) 22%, transparent)"
    },
    "axis": { "$type": "cssValue", "$value": "var(--t3, var(--text-muted))" },
    "tooltip-bg": { "$type": "cssValue", "$value": "var(--card)" },
    "tooltip-border": {
      "$type": "cssValue",
      "$value": "var(--border-l, var(--border))"
    },
    "line": { "$type": "cssValue", "$value": "var(--accent)" },
    "line-2": { "$type": "cssValue", "$value": "var(--accent-2, var(--accent))" },
    "positive": { "$type": "cssValue", "$value": "var(--positive)" },
    "warning": { "$type": "cssValue", "$value": "var(--warning)" },
    "critical": { "$type": "cssValue", "$value": "var(--critical)" },
    "info": { "$type": "cssValue", "$value": "var(--info)" }
  },
  "chartHue": {
    "$description": "8 个具名色相(dataviz 六项检查验证过的固定 CVD 安全色相族),亮暗各自选定:light on #ffffff worst adjacent ΔE 24.2;dark on #141815 worst 10.3(floor band——组件必须带图例/直接标注/2px 间隙作次级编码)。chartSeries 槽位只是这 8 个色相的一种排列;品牌若与某色相撞色(如 finance 撞 green、portal 撞 blue),在 brands/*.json 里重排槽位→色相的映射即可,不需要新色号也不需要重新验证——排列变化只影响相邻对,已在 CHANGELOG 里跑过 validate_palette.js 确认。",
    "light": {
      "blue": { "$type": "color", "$value": "#2a78d6" },
      "aqua": { "$type": "color", "$value": "#1baf7a" },
      "yellow": { "$type": "color", "$value": "#eda100" },
      "green": { "$type": "color", "$value": "#008300" },
      "violet": { "$type": "color", "$value": "#4a3aa7" },
      "red": { "$type": "color", "$value": "#e34948" },
      "magenta": { "$type": "color", "$value": "#e87ba4" },
      "orange": { "$type": "color", "$value": "#eb6834" }
    },
    "dark": {
      "blue": { "$type": "color", "$value": "#3987e5" },
      "aqua": { "$type": "color", "$value": "#199e70" },
      "yellow": { "$type": "color", "$value": "#c98500" },
      "green": { "$type": "color", "$value": "#008300" },
      "violet": { "$type": "color", "$value": "#9085e9" },
      "red": { "$type": "color", "$value": "#e66767" },
      "magenta": { "$type": "color", "$value": "#d55181" },
      "orange": { "$type": "color", "$value": "#d95926" }
    }
  },
  "chartSeries": {
    "$description": "Categorical 系列色板(多系列图表用,固定槽位顺序即 CVD 安全机制,禁止循环取色)。默认排列 = chartHue 的原始顺序(blue,aqua,yellow,green,violet,red,magenta,orange)。单系列图表不走槽位,用 --chart-line(品牌 accent)。",
    "light": {
      "1": { "$type": "cssValue", "$value": "var(--chart-hue-blue)" },
      "2": { "$type": "cssValue", "$value": "var(--chart-hue-aqua)" },
      "3": { "$type": "cssValue", "$value": "var(--chart-hue-yellow)" },
      "4": { "$type": "cssValue", "$value": "var(--chart-hue-green)" },
      "5": { "$type": "cssValue", "$value": "var(--chart-hue-violet)" },
      "6": { "$type": "cssValue", "$value": "var(--chart-hue-red)" },
      "7": { "$type": "cssValue", "$value": "var(--chart-hue-magenta)" },
      "8": { "$type": "cssValue", "$value": "var(--chart-hue-orange)" }
    },
    "dark": {
      "1": { "$type": "cssValue", "$value": "var(--chart-hue-blue)" },
      "2": { "$type": "cssValue", "$value": "var(--chart-hue-aqua)" },
      "3": { "$type": "cssValue", "$value": "var(--chart-hue-yellow)" },
      "4": { "$type": "cssValue", "$value": "var(--chart-hue-green)" },
      "5": { "$type": "cssValue", "$value": "var(--chart-hue-violet)" },
      "6": { "$type": "cssValue", "$value": "var(--chart-hue-red)" },
      "7": { "$type": "cssValue", "$value": "var(--chart-hue-magenta)" },
      "8": { "$type": "cssValue", "$value": "var(--chart-hue-orange)" }
    }
  },
  "contract": {
    "$description": "Semantic vars every brand's default mode must define. Text tiers accept either the t1..t4 stack (planner/fitness/music) or the text/text-secondary/text-muted stack (finance/fitness).",
    "requiredBrandVars": ["bg", "card", "border", "accent", "on-accent", "sidebar"],
    "requiredTextVars": {
      "anyOf": [
        ["t1", "t2", "t3"],
        ["text", "text-secondary", "text-muted"]
      ]
    }
  }
}
