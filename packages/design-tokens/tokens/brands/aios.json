{
  "app": "aios",
  "defaultMode": "light",
  "modes": {
    "light": {
      "colorScheme": "light",
      "vars": {
        "bg": { "$type": "color", "$value": "#ffffff" },
        "bg-2": { "$type": "color", "$value": "#f9f9f9" },
        "card": { "$type": "color", "$value": "#f4f4f4" },
        "card-h": { "$type": "color", "$value": "#ececec" },
        "border": { "$type": "color", "$value": "rgba(0, 0, 0, 0.08)" },
        "border-l": { "$type": "color", "$value": "rgba(0, 0, 0, 0.14)" },
        "t1": { "$type": "color", "$value": "#0d0d0d" },
        "t2": { "$type": "color", "$value": "#5d5d5d" },
        "t3": { "$type": "color", "$value": "#8f8f8f" },
        "t4": { "$type": "color", "$value": "#b4b4b4" },
        "accent": { "$type": "color", "$value": "#0d0d0d" },
        "accent-2": { "$type": "color", "$value": "#2f2f2f" },
        "accent-strong": { "$type": "color", "$value": "#000000" },
        "accent-bg": { "$type": "color", "$value": "rgba(13, 13, 13, 0.06)" },
        "on-accent": { "$type": "color", "$value": "#ffffff" },
        "sidebar": { "$type": "color", "$value": "#f9f9f9" },
        "sidebar-foreground": { "$type": "color", "$value": "#0d0d0d" },
        "sidebar-muted": {
          "$type": "color",
          "$value": "rgba(13, 13, 13, 0.55)"
        },
        "sidebar-accent": { "$type": "color", "$value": "#ececec" },
        "sidebar-primary": { "$type": "color", "$value": "#0d0d0d" },
        "sidebar-primary-foreground": { "$type": "color", "$value": "#ffffff" },
        "sidebar-border": { "$type": "color", "$value": "rgba(0, 0, 0, 0.06)" },
        "appbar-bg": {
          "$type": "color",
          "$value": "rgba(255, 255, 255, 0.88)"
        },
        "nav-bg": { "$type": "color", "$value": "rgba(249, 249, 249, 0.92)" },
        "seg-track-bg": { "$type": "color", "$value": "#ececec" },
        "seg-active-bg": { "$type": "color", "$value": "#ffffff" },
        "seg-active-fg": { "$type": "color", "$value": "#0d0d0d" },
        "sb-thumb": { "$type": "color", "$value": "rgba(0, 0, 0, 0.18)" },
        "sb-thumb-hover": { "$type": "color", "$value": "rgba(0, 0, 0, 0.32)" }
      }
    },
    "dark": {
      "colorScheme": "dark",
      "vars": {
        "bg": { "$type": "color", "$value": "#212121" },
        "bg-2": { "$type": "color", "$value": "#171717" },
        "card": { "$type": "color", "$value": "#2f2f2f" },
        "card-h": { "$type": "color", "$value": "#383838" },
        "border": { "$type": "color", "$value": "rgba(255, 255, 255, 0.08)" },
        "border-l": { "$type": "color", "$value": "rgba(255, 255, 255, 0.15)" },
        "t1": { "$type": "color", "$value": "#ececec" },
        "t2": { "$type": "color", "$value": "#b4b4b4" },
        "t3": { "$type": "color", "$value": "#8f8f8f" },
        "t4": { "$type": "color", "$value": "rgba(236, 236, 236, 0.4)" },
        "accent": { "$type": "color", "$value": "#ececec" },
        "accent-2": { "$type": "color", "$value": "#ffffff" },
        "accent-strong": { "$type": "color", "$value": "#ffffff" },
        "accent-bg": {
          "$type": "color",
          "$value": "rgba(236, 236, 236, 0.1)"
        },
        "on-accent": { "$type": "color", "$value": "#0d0d0d" },
        "sidebar": { "$type": "color", "$value": "#171717" },
        "sidebar-foreground": { "$type": "color", "$value": "#ececec" },
        "sidebar-muted": {
          "$type": "color",
          "$value": "rgba(236, 236, 236, 0.55)"
        },
        "sidebar-accent": { "$type": "color", "$value": "#242424" },
        "sidebar-primary": { "$type": "color", "$value": "#ececec" },
        "sidebar-primary-foreground": { "$type": "color", "$value": "#0d0d0d" },
        "sidebar-border": {
          "$type": "color",
          "$value": "rgba(255, 255, 255, 0.07)"
        },
        "appbar-bg": { "$type": "color", "$value": "rgba(33, 33, 33, 0.88)" },
        "nav-bg": { "$type": "color", "$value": "rgba(23, 23, 23, 0.92)" },
        "seg-track-bg": { "$type": "color", "$value": "#212121" },
        "seg-active-bg": { "$type": "color", "$value": "#4a4a4a" },
        "seg-active-fg": { "$type": "color", "$value": "#ececec" },
        "sb-thumb": { "$type": "color", "$value": "rgba(255, 255, 255, 0.16)" },
        "sb-thumb-hover": {
          "$type": "color",
          "$value": "rgba(255, 255, 255, 0.3)"
        }
      }
    }
  }
}
