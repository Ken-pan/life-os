        },
        "nav-bg": {
          "$type": "color",
          "$value": "rgba(255, 255, 255, 0.92)"
        },
        "seg-display": {
          "$type": "cssValue",
          "$value": "flex"
        },
        "seg-flex-wrap": {
          "$type": "cssValue",
          "$value": "wrap"
        },
        "seg-gap": {
          "$type": "dimension",
          "$value": "8px"
        },
        "seg-track-bg": {
          "$type": "cssValue",
          "$value": "transparent"
        },
        "seg-track-border": {
          "$type": "cssValue",
          "$value": "none"
        },
        "seg-track-padding": {
          "$type": "cssValue",
          "$value": "0"
        },
        "seg-btn-bg": {
          "$type": "cssValue",
          "$value": "var(--card)"
        },
        "seg-btn-border": {
          "$type": "cssValue",
          "$value": "1px solid var(--border)"
        },
        "seg-active-bg": {
          "$type": "cssValue",
          "$value": "var(--accent-bg)"
        },
        "seg-active-fg": {
          "$type": "cssValue",
          "$value": "var(--accent)"
        },
        "seg-active-border-token": {
          "$type": "cssValue",
          "$value": "var(--accent)"
        }
      }
    },
    "dark": {
      "colorScheme": "dark",
      "vars": {
