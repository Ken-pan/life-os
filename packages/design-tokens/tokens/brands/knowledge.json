{
  "app": "knowledge",
  "defaultMode": "light",
  "modes": {
    "light": {
      "colorScheme": "light",
      "vars": {
        "bg": {
          "$type": "color",
          "$value": "#f7f6f2"
        },
        "bg-2": {
          "$type": "color",
          "$value": "#fffdf9"
        },
        "card": {
          "$type": "color",
          "$value": "#ffffff"
        },
        "card-h": {
          "$type": "color",
          "$value": "#efedf7"
        },
        "border": {
          "$type": "color",
          "$value": "#dedbe4"
        },
        "border-l": {
          "$type": "color",
          "$value": "#c8c4d4"
        },
        "t1": {
          "$type": "color",
          "$value": "#191823"
        },
        "t2": {
          "$type": "color",
          "$value": "#4e4c5e"
        },
        "t3": {
          "$type": "color",
          "$value": "#6f6d80"
        },
        "t4": {
          "$type": "color",
          "$value": "#918fa0"
        },
        "accent": {
          "$type": "color",
          "$value": "#4d55c7"
        },
        "accent-2": {
          "$type": "color",
          "$value": "#3a41a8"
        },
        "accent-bg": {
          "$type": "color",
          "$value": "rgba(77, 85, 199, 0.1)"
        },
        "on-accent": {
          "$type": "color",
          "$value": "#ffffff"
        },
        "sidebar": {
          "$type": "color",
          "$value": "#1a1926"
        },
        "sidebar-foreground": {
          "$type": "color",
          "$value": "#efeef6"
        },
        "sidebar-muted": {
          "$type": "color",
          "$value": "rgba(239, 238, 246, 0.55)"
        },
        "sidebar-accent": {
          "$type": "color",
          "$value": "#242236"
        },
        "sidebar-primary": {
          "$type": "color",
          "$value": "#9aa2ff"
        },
        "sidebar-primary-foreground": {
          "$type": "color",
          "$value": "#12121c"
        },
        "sidebar-border": {
          "$type": "color",
          "$value": "rgba(255, 255, 255, 0.08)"
        },
        "appbar-bg": {
          "$type": "color",
          "$value": "rgba(247, 246, 242, 0.88)"
        },
        "nav-bg": {
          "$type": "color",
          "$value": "rgba(255, 255, 255, 0.92)"
        },
        "seg-display": {
          "$type": "cssValue",
          "$value": "flex"
        },
        "seg-flex-wrap": {
          "$type": "cssValue",
          "$value": "wrap"
        },
        "seg-gap": {
          "$type": "dimension",
          "$value": "8px"
        },
        "seg-track-bg": {
          "$type": "cssValue",
          "$value": "transparent"
        },
        "seg-track-border": {
          "$type": "cssValue",
          "$value": "none"
        },
        "seg-track-padding": {
          "$type": "cssValue",
          "$value": "0"
        },
        "seg-btn-bg": {
          "$type": "cssValue",
          "$value": "var(--card)"
        },
        "seg-btn-border": {
          "$type": "cssValue",
          "$value": "1px solid var(--border)"
        },
        "seg-active-bg": {
          "$type": "cssValue",
          "$value": "var(--accent-bg)"
        },
        "seg-active-fg": {
          "$type": "cssValue",
          "$value": "var(--accent)"
        },
        "seg-active-border-token": {
          "$type": "cssValue",
          "$value": "var(--accent)"
        },
        "chart-series-1": { "$type": "cssValue", "$value": "var(--chart-hue-blue)" },
        "chart-series-2": { "$type": "cssValue", "$value": "var(--chart-hue-aqua)" },
        "chart-series-3": { "$type": "cssValue", "$value": "var(--chart-hue-yellow)" },
        "chart-series-4": { "$type": "cssValue", "$value": "var(--chart-hue-green)" },
        "chart-series-5": { "$type": "cssValue", "$value": "var(--chart-hue-red)" },
        "chart-series-6": { "$type": "cssValue", "$value": "var(--chart-hue-magenta)" },
        "chart-series-7": { "$type": "cssValue", "$value": "var(--chart-hue-orange)" },
        "chart-series-8": { "$type": "cssValue", "$value": "var(--chart-hue-violet)" }
      }
    },
