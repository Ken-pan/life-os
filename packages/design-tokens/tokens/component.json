{
  "focus": {
    "ring": {
      "$type": "cssValue",
      "$value": "var(--btn-focus-ring, 0 0 0 2px color-mix(in srgb, var(--accent) 32%, transparent))"
    },
    "offset": { "$type": "dimension", "$value": "2px" }
  },
  "overlay": {
    "backdrop": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--t1, var(--text)) 55%, transparent)"
    }
  },
  "card": {
    "bg": { "$type": "color", "$value": "var(--card)" },
    "bgHover": { "$type": "color", "$value": "var(--card-h)" },
    "bgSelected": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--accent) 8%, var(--card))"
    },
    "border": { "$type": "color", "$value": "var(--border)" },
    "borderHover": {
      "$type": "color",
      "$value": "var(--border-l, var(--border))"
    },
    "radius": { "$type": "dimension", "$value": "var(--radius-sm, 14px)" },
    "padding": { "$type": "dimension", "$value": "var(--space-4)" },
    "paddingCompact": { "$type": "dimension", "$value": "var(--space-3)" },
    "gap": { "$type": "dimension", "$value": "var(--space-3)" },
    "shadow": {
      "$type": "cssValue",
      "$value": "var(--shadow-soft, 0 1px 2px color-mix(in srgb, var(--t1, var(--text)) 4%, transparent))"
    },
    "shadowHover": {
      "$type": "cssValue",
      "$value": "var(--shadow-card, var(--shadow-soft))"
    },
    "titleColor": { "$type": "color", "$value": "var(--t1, var(--text))" },
    "descriptionColor": {
      "$type": "color",
      "$value": "var(--t2, var(--text-secondary, var(--text-muted)))"
    },
    "mediaRadius": {
      "$type": "dimension",
      "$value": "var(--radius-control, 8px)"
    },
    "footerBorder": { "$type": "color", "$value": "var(--border)" },
    "focusRing": { "$type": "cssValue", "$value": "var(--focus-ring)" },
    "disabledOpacity": { "$type": "number", "$value": "0.55" }
  },
  "control": {
    "bg": { "$type": "color", "$value": "var(--card)" },
    "bgHover": { "$type": "color", "$value": "var(--card-h)" },
    "border": { "$type": "color", "$value": "var(--border)" },
    "text": { "$type": "color", "$value": "var(--t1, var(--text))" },
    "textMuted": { "$type": "color", "$value": "var(--t3, var(--text-muted))" },
    "sectionRadius": {
      "$type": "dimension",
      "$value": "var(--radius-lg, 12px)"
    },
    "sectionPadding": { "$type": "dimension", "$value": "var(--card-padding)" },
    "toggleTrack": {
      "$type": "color",
      "$value": "var(--border-l, var(--border-strong, var(--border)))"
    },
    "toggleThumb": {
      "$type": "color",
      "$value": "var(--bg-elevated, #ffffff)"
    },
    "toggleOn": {
      "$type": "color",
      "$value": "var(--toggle-on-bg, var(--accent))"
    },
    "toggleDisabledOpacity": { "$type": "number", "$value": "0.45" }
  },
  "button": {
    "primaryBg": { "$type": "color", "$value": "var(--accent)" },
    "primaryText": { "$type": "color", "$value": "var(--on-accent)" },
    "secondaryBg": {
      "$type": "color",
      "$value": "var(--card-h, var(--card-hover, var(--surface-2)))"
    },
    "secondaryBorder": {
      "$type": "color",
      "$value": "var(--border-l, var(--border-strong, var(--border)))"
    },
    "secondaryText": { "$type": "color", "$value": "var(--t1, var(--text))" },
    "ghostText": {
      "$type": "color",
      "$value": "var(--t2, var(--text-secondary))"
    },
    "ghostBgHover": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--t1, var(--text)) 5%, transparent)"
    },
    "dangerBg": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--critical) 8%, transparent)"
    },
    "dangerBgHover": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--critical) 15%, transparent)"
    },
    "dangerBorder": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--critical) 24%, transparent)"
    },
    "dangerBorderHover": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--critical) 42%, transparent)"
    },
    "dangerText": { "$type": "color", "$value": "var(--critical)" },
    "disabledOpacity": { "$type": "number", "$value": "0.42" },
    "focusRing": { "$type": "cssValue", "$value": "var(--focus-ring)" }
  },
  "segment": {
    "trackBg": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--t1, var(--text)) 4%, var(--bg-elevated, var(--card)))"
    },
    "trackRadius": { "$type": "dimension", "$value": "var(--radius-pill)" },
    "btnBg": { "$type": "color", "$value": "transparent" },
    "btnColor": {
      "$type": "color",
      "$value": "var(--t2, var(--text-secondary))"
    },
    "activeBg": {
      "$type": "color",
      "$value": "var(--lime, var(--accent-bg, var(--accent-subtle)))"
    },
    "activeFg": { "$type": "color", "$value": "var(--on-lime, var(--accent))" }
  },
  "feedback": {
    "success": { "$type": "color", "$value": "var(--positive)" },
    "successBg": { "$type": "color", "$value": "var(--positive-subtle)" },
    "successBorder": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--feedback-success) 32%, var(--border))"
    },
    "warning": { "$type": "color", "$value": "var(--warning)" },
    "warningBg": { "$type": "color", "$value": "var(--warning-subtle)" },
    "warningBorder": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--feedback-warning) 38%, var(--border))"
    },
    "danger": { "$type": "color", "$value": "var(--critical)" },
    "dangerBg": { "$type": "color", "$value": "var(--critical-subtle)" },
    "dangerBorder": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--feedback-danger) 32%, var(--border))"
    },
    "info": { "$type": "color", "$value": "var(--info, var(--accent))" },
    "infoBg": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--feedback-info) 16%, var(--card))"
    },
    "infoBorder": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--feedback-info) 40%, var(--border))"
    }
  },
  "navigation": {
    "itemBg": { "$type": "color", "$value": "transparent" },
    "itemBgActive": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--accent) 10%, var(--card))"
    },
    "itemText": {
      "$type": "color",
      "$value": "var(--t2, var(--text-secondary, var(--text-muted)))"
    },
    "itemTextActive": { "$type": "color", "$value": "var(--accent)" },
    "backText": {
      "$type": "color",
      "$value": "var(--t2, var(--text-secondary))"
    },
    "backTextHover": { "$type": "color", "$value": "var(--t1, var(--text))" },
    "backTextActive": {
      "$type": "color",
      "$value": "var(--t3, var(--text-muted))"
    },
    "backMarginBottom": { "$type": "cssValue", "$value": "0" },
    "backMarginInlineStart": { "$type": "cssValue", "$value": "0" },
    "backPaddingInlineEnd": { "$type": "cssValue", "$value": "0" },
    "backIconSize": { "$type": "dimension", "$value": "13px" },
    "sheetBg": { "$type": "color", "$value": "var(--card)" },
    "sheetRadius": { "$type": "dimension", "$value": "var(--radius-overlay, 20px)" }
  },
  "commandPalette": {
    "containerBg": { "$type": "color", "$value": "var(--card)" },
    "containerRadius": { "$type": "dimension", "$value": "16px" },
    "containerBorder": {
      "$type": "color",
      "$value": "var(--border-l, var(--border-strong, var(--border)))"
    },
    "containerShadow": {
      "$type": "cssValue",
      "$value": "var(--shadow-elevated, var(--card-shadow-hover))"
    },
    "headerHeight": { "$type": "dimension", "$value": "56px" },
    "headerBorder": { "$type": "color", "$value": "var(--border)" },
    "inputText": { "$type": "color", "$value": "var(--t1, var(--text))" },
    "inputPlaceholder": {
      "$type": "color",
      "$value": "var(--t3, var(--text-muted))"
    },
    "itemSelectedBg": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--t1, var(--text)) 5%, transparent)"
    },
    "itemIcon": {
      "$type": "color",
      "$value": "var(--t2, var(--text-secondary))"
    },
    "itemIconActive": { "$type": "color", "$value": "var(--accent)" },
    "itemTitle": { "$type": "color", "$value": "var(--t1, var(--text))" },
    "itemSubtitle": {
      "$type": "color",
      "$value": "var(--t3, var(--text-muted))"
    },
    "itemShortcutBg": { "$type": "color", "$value": "var(--bg, var(--card))" },
    "itemShortcutBorder": { "$type": "color", "$value": "var(--border)" },
    "hintBg": {
      "$type": "color",
      "$value": "color-mix(in srgb, var(--t1, var(--text)) 5%, transparent)"
    },
    "hintText": { "$type": "color", "$value": "var(--t3, var(--text-muted))" },
    "emptyText": { "$type": "color", "$value": "var(--t3, var(--text-muted))" },
    "contentMaxHeight": { "$type": "cssValue", "$value": "400px" },
    "mobileContentMaxHeight": { "$type": "cssValue", "$value": "60vh" },
    "mobileSheetRadius": { "$type": "cssValue", "$value": "var(--radius-overlay, 20px) var(--radius-overlay, 20px) 0 0" }
  },
  "portraitGate": {
    "overlayBg": { "$type": "color", "$value": "var(--bg)" },
    "overlayText": { "$type": "color", "$value": "var(--t1, var(--text))" },
    "hintText": {
      "$type": "color",
      "$value": "var(--t2, var(--text-secondary))"
    },
    "titleSize": { "$type": "dimension", "$value": "18px" },
    "hintSize": { "$type": "dimension", "$value": "14px" },
    "iconSize": { "$type": "dimension", "$value": "48px" },
    "innerMaxWidth": { "$type": "dimension", "$value": "320px" }
  }
}
