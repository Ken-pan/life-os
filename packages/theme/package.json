{
  "name": "@life-os/theme",
  "version": "1.5.0",
  "private": true,
  "description": "Life OS shared theme: layout breakpoints, site metadata, theme runtime",
  "type": "module",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./layout.css": "./src/layout.css",
    "./media.css": "./src/media.css",
    "./design-system.css": "./src/design-system.css",
    "./ua-reset.css": "./src/ua-reset.css",
    "./utilities.css": "./src/utilities.css",
    "./ios-safari.css": "./src/ios-safari.css",
    "./scroll-shell.css": "./src/scroll-shell.css",
    "./tokens.css": "./src/tokens.css",
    "./component.css": "./src/generated/component.css",
    "./seg.css": "./src/seg.css",
    "./app-themes.css": "./src/app-themes.css",
    "./brands/planner.css": "./src/generated/brands/planner.css",
    "./brands/fitness.css": "./src/generated/brands/fitness.css",
    "./brands/finance.css": "./src/generated/brands/finance.css",
    "./brands/music.css": "./src/generated/brands/music.css",
    "./brands/home.css": "./src/generated/brands/home.css",
    "./brands/aios.css": "./src/generated/brands/aios.css",
    "./brands/portal.css": "./src/generated/brands/portal.css",
    "./brands/knowledge.css": "./src/generated/brands/knowledge.css",
    "./brands/health.css": "./src/generated/brands/health.css",
    "./brand": {
      "types": "./src/index.d.ts",
      "import": "./src/brand.js"
    },
    "./launcher": {
      "types": "./src/index.d.ts",
      "import": "./src/launcher.js"
    }
  }
}
