{
  "name": "life-os",
  "private": true,
  "description": "Life OS monorepo — Planner, Fitness, Finance, Music + shared theme/sync",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "build:planner": "npm run build -w planner-os",
    "build:fitness": "npm run build -w fitness-os",
    "build:finance": "npm run build -w finance-os",
    "build:music": "npm run build -w music-os",
    "build:portal": "npm run build -w portal",
    "build:home": "npm run build -w home-os",
    "build:health": "npm run build -w health-os",
    "build:knowledge": "npm run build -w knowledge-os",
    "build:aios": "npm run build -w aios-os",
    "app:aios": "bash scripts/aios/build-app.sh",
    "app:health": "bash scripts/health/build-app.sh",
    "verify:web-state": "npm run verify --prefix ../web-state-devtools/bridge",
    "qa:mobile-scroll": "node scripts/life-os-mobile-scroll-qa.mjs",
    "qa:screenshots:prune": "node scripts/qa/prune-screenshots.mjs",
    "qa:screenshots:cleanup": "node scripts/qa/cleanup-legacy-screenshots.mjs",
    "check:lifeos-boundaries": "node scripts/check-lifeos-boundaries.mjs",
    "check:lifeos-styles": "node scripts/check-lifeos-styles.mjs",
    "check:app-manifests": "node scripts/build-app-registry.mjs --check",
    "check:design-catalog-registry": "node scripts/check-design-catalog-registry.mjs",
    "qa:prod-a11y": "node scripts/lifeos-prod-a11y-spotcheck.mjs",
    "build:app-registry": "node scripts/build-app-registry.mjs",
    "add:capability": "node scripts/add-capability.mjs",
    "verify:ticket-naming": "node scripts/verify-ticket-naming.mjs",
    "generate:brand-icons": "python3 scripts/generate-life-os-brand-icons.py",
    "verify:identity-p0": "./scripts/verify-life-os-identity-p0.sh",
    "verify:outbox": "./scripts/test-outbox-trigger.sh --smoke",
    "pwa:build": "npm run build:planner && npm run build:fitness && npm run build:finance && npm run build:music && npm run build:portal",
    "pwa:preview:planner": "bash scripts/pwa/preview-app.sh planner",
    "pwa:preview:fitness": "bash scripts/pwa/preview-app.sh fitness",
    "pwa:preview:music": "bash scripts/pwa/preview-app.sh music",
    "pwa:preview:finance": "bash scripts/pwa/preview-app.sh finance",
    "pwa:preview:portal": "bash scripts/pwa/preview-app.sh portal",
    "pwa:preview:home": "bash scripts/pwa/preview-app.sh home",
    "pwa:preview:health": "bash scripts/pwa/preview-app.sh health",
    "pwa:preview:knowledge": "bash scripts/pwa/preview-app.sh knowledge",
    "pwa:healthcheck": "node scripts/pwa/pwa-healthcheck.mjs",
    "pwa:sim:open": "bash scripts/pwa/ios-sim-open.sh",
    "pwa:sim:shot": "bash scripts/pwa/ios-sim-screenshot.sh",
    "pwa:sim:capture": "node scripts/pwa/capture-sim-screenshots.mjs",
    "pwa:metrics": "node scripts/pwa/collect-viewport-metrics.mjs",
    "test:pwa": "playwright test",
    "qa:pwa": "npm run pwa:healthcheck && npm run test:pwa && npm run qa:mobile-scroll",
    "dev:design-catalog": "npm run dev -w design-catalog",
    "test:design-catalog": "playwright test -c playwright.design-catalog.config.ts --grep-invert \"@(visual|a11y)\"",
    "test:design-catalog:a11y": "playwright test -c playwright.design-catalog.config.ts --grep @a11y --project catalog-desktop",
    "test:design-catalog:snapshots": "playwright test -c playwright.design-catalog.config.ts --grep @visual --project catalog-desktop",
    "test:design-catalog:snapshots:update": "playwright test -c playwright.design-catalog.config.ts --grep @visual --project catalog-desktop --update-snapshots",
    "test:design-catalog:snapshots:canonical": "bash scripts/design-catalog-snapshots-docker.sh",
    "test:design-catalog:all": "playwright test -c playwright.design-catalog.config.ts",
    "build:tokens": "node packages/design-tokens/scripts/build-css.mjs",
    "validate:tokens": "node packages/design-tokens/scripts/validate-tokens.mjs",
    "ios:add": "node scripts/ios/add-ios.mjs",
    "ios:device": "node scripts/ios/deploy-device.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "playwright": "^1.61.1",
    "turbo": "^2.5.4"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.7"
}
