{
  "manifest_version": 3,
  "name": "Finance OS Sync",
  "version": "0.4.0",
  "description": "从 Robinhood / Rocket Money / Fidelity 抓取持仓、余额与交易，并定向抓取 Amazon / Target / Best Buy 最新订单做购买标注，同步到 Finance OS（Life OS / Supabase public schema）。交易支持登录后直连落库，无需打开 Finance OS 页面。",
  "permissions": ["storage", "activeTab", "tabs", "alarms"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "Finance OS Sync"
  },
  "content_scripts": [
    {
      "matches": ["https://robinhood.com/*"],
      "js": [
        "content/common.js",
        "rhDetailsShared.js",
        "rhFinanceProbes.js",
        "content/robinhood.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://app.rocketmoney.com/*"],
      "js": [
        "content/common.js",
        "rmFinanceProbes.js",
        "content/syncPlan.js",
        "content/rocketmoney.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://digital.fidelity.com/*",
        "https://www.fidelity.com/*",
        "https://oltx.fidelity.com/*"
      ],
      "js": ["content/common.js", "content/fidelity.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.amazon.com/your-orders/*",
        "https://www.amazon.com/gp/your-account/order-details*",
        "https://www.amazon.com/gp/css/order-history*"
      ],
      "js": [
        "content/common.js",
        "vendor/amazon-orders.js",
        "content/merchantOrders.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.target.com/orders*"],
      "js": [
        "content/common.js",
        "vendor/target-orders.js",
        "content/merchantOrders.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.bestbuy.com/purchasehistory/*",
        "https://www.bestbuy.com/profile/ss/orders/*"
      ],
      "js": [
        "content/common.js",
        "vendor/bestbuy-orders.js",
        "content/merchantOrders.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://finance.kenos.space/*",
        "https://*.netlify.app/*"
      ],
      "js": ["content/bridge.js"],
      "run_at": "document_start"
    }
  ]
}
