# Life OS（原 Finance OS + FitnessOS 合并后的 Supabase 项目）
# 来源：Supabase 控制台 → Life OS → Settings → API
VITE_SUPABASE_URL=https://iueozzuctstwvzbcxcyh.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_V_BnCiRU9vozOl3VLL8AAg_KsUfDEcL

# Kimi (Moonshot) API key，用于 AI 财务简报。只在服务端代理使用（不带 VITE_ 前缀，不会进前端 bundle）。
# 生产部署时在 Netlify 站点环境变量里配置同名 KIMI_API_KEY。
KIMI_API_KEY=sk-your-moonshot-api-key

# 本地 IA 埋点（localStorage）。设为 false 可关闭导航/漏斗事件采集。
# VITE_ANALYTICS_ENABLED=false

# 可选：将埋点 JSON POST 到远程收集端（如自建 webhook / Zapier）。
# VITE_ANALYTICS_WEBHOOK_URL=https://example.com/analytics
