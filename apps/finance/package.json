{
  "name": "finance-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "pwa:preview": "vite preview -- --host 0.0.0.0 --port 5180",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "typecheck": "npm run check",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch-logos": "node scripts/fetch-institution-logos.mjs",
    "link:amazon": "node --experimental-strip-types scripts/link-amazon-orders.mjs",
    "link:purchase": "node --experimental-strip-types scripts/link-purchase-orders.mjs",
    "fix:legacy-txns": "node scripts/fix-legacy-import-txns.mjs",
    "qa:amazon-enrichment": "node scripts/amazon-enrichment-screenshot-qa.mjs",
    "qa:fp6:bootstrap": "node scripts/finance-qa-bootstrap.mjs",
    "qa:fp6:teardown": "node scripts/finance-qa-bootstrap.mjs --teardown",
    "qa:records-tab": "node scripts/records-tab-ux-audit.mjs",
    "guard:overflow": "vitest run src/debug/overflowGuard.test.ts",
    "qa:screenshots": "node scripts/ui-main-flows-screenshot-qa.mjs",
    "qa:ia-routes": "node scripts/ia-route-smoke.mjs",
    "qa:ia-nav": "node scripts/ia-nav-qa.mjs"
  },
  "dependencies": {
    "@life-os/contracts": "*",
    "@life-os/finance-core": "*",
    "@life-os/finance-enrichment-contract": "*",
    "@life-os/platform-web": "*",
    "@life-os/sync": "*",
    "@life-os/theme": "*",
    "@lucide/svelte": "^1.22.0",
    "@supabase/supabase-js": "^2.106.2",
    "layerchart": "2.0.0-next.57"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@vitest/browser": "^3.2.4",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "postcss-custom-media": "^12.0.1",
    "simple-icons": "^16.24.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^3.2.4",
    "vitest-browser-svelte": "^0.1.0"
  }
