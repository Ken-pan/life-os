    "test:localize": "node scripts/localize-unit.mjs",
    "test:viewpoint-ui": "node scripts/viewpoint-smoke.mjs",
    "test:viewport": "node scripts/plan-viewport-stress.mjs",
    "test:plan-edit": "node scripts/plan-edit-smoke.mjs",
    "test:doors": "node scripts/door-styles-unit.mjs",
    "test:windows": "node scripts/window-styles-unit.mjs",
    "test:rooms": "node scripts/rooms-detect-test.mjs",
    "test:snap": "node scripts/snap-test.mjs",
    "test:storage": "node scripts/storage-items-unit.mjs",
    "test:cloud-scan": "node scripts/cloud-scan-unit.mjs",
    "test:circulation": "node scripts/circulation-unit.mjs",
    "test:scan-merge": "node scripts/scan-merge-unit.mjs",
    "test:scan-accuracy": "node scripts/scan-accuracy.mjs",
