{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "AIOS 主窗口权限:核心 + 受限 shell(只允许白名单里的命令,args 任意)",
  "windows": ["main", "pet"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-webview-close",
    "core:webview:allow-webview-show",
    "core:webview:allow-webview-hide",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-set-visible-on-all-workspaces",
    "core:window:allow-set-position",
    "core:window:allow-outer-position",
    "core:window:allow-outer-size",
    "core:window:allow-scale-factor",
    "core:window:allow-start-dragging",
    "process:default",
    "macos-permissions:default",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "claude", "cmd": "/Users/kenpan/.local/bin/claude", "args": true },
        { "name": "cursor-agent", "cmd": "/Users/kenpan/.local/bin/cursor-agent", "args": true },
        { "name": "gh", "cmd": "/opt/homebrew/bin/gh", "args": true },
        { "name": "sqlite3", "cmd": "/usr/bin/sqlite3", "args": true },
        { "name": "osascript", "cmd": "/usr/bin/osascript", "args": true },
        { "name": "screencapture", "cmd": "/usr/sbin/screencapture", "args": true },
        { "name": "sips", "cmd": "/usr/bin/sips", "args": true },
        { "name": "base64", "cmd": "/usr/bin/base64", "args": true },
        { "name": "open", "cmd": "/usr/bin/open", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "claude", "cmd": "/Users/kenpan/.local/bin/claude", "args": true },
        { "name": "cursor-agent", "cmd": "/Users/kenpan/.local/bin/cursor-agent", "args": true },
        { "name": "gh", "cmd": "/opt/homebrew/bin/gh", "args": true },
        { "name": "osascript", "cmd": "/usr/bin/osascript", "args": true }
      ]
    }
  ]
}
