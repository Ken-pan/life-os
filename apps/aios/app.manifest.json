{
  "id": "aios",
  "name": "Kenos Assistant",
  "shortName": "Assistant",
  "description": {
    "zh": "Kenos 默认协调入口 · Today、Assistant、Inbox、审批与 Activity",
    "en": "The Kenos coordination entry · Today, Assistant, Inbox, approvals, and Activity"
  },
  "themeColor": {
    "light": "#ffffff",
    "dark": "#08090a"
  },
  "defaultTheme": "auto",
  "locale": "zh-CN",
  "storageKey": "aiosos_v1",
  "storageKind": "nested",
  "settingsThemePath": [
    "settings",
    "theme"
  ],
  "categories": [
    "utilities"
  ],
  "workspace": "aios-os",
  "devPort": 5197,
  "domain": "www.kenos.space",
  "shellType": "main-wrap-main",
  "wordmarkAccent": {
    "light": "#5d5d5d",
    "dark": "#b4b4b4"
  },
  "experimental": true,
  "switcherOrder": 60,
  "production": false,
  "pwaTestEnabled": true,
  "routes": [
    {
      "path": "/",
      "name": "today"
    },
    {
      "path": "/assistant",
      "name": "assistant"
    },
    {
      "path": "/chat",
      "name": "assistant-legacy"
    },
    {
      "path": "/inbox",
      "name": "inbox"
    },
    {
      "path": "/approvals",
      "name": "approvals"
    },
    {
      "path": "/activity",
      "name": "activity"
    },
    {
      "path": "/work",
      "name": "work"
    },
    {
      "path": "/history",
      "name": "history"
    },
    {
      "path": "/settings",
      "name": "settings"
    }
  ],
  "clipPaths": [
    "/assistant"
  ],
  "scrollQaPath": "/settings"
}
