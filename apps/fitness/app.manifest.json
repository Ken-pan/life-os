  "workspace": "fitness-os",
  "devPort": 5190,
  "previewPort": 4173,
  "domain": "fitness.kenos.space",
  "shellType": "main-wrap-main",
  "wordmarkAccent": { "light": "#c42f0a", "dark": "#ff4d2e" },
  "switcherOrder": 30,
  "registryOrder": 2,
  "pwaName": "Fitness.OS",
  "favicon": { "light": "/favicon-32.png" },
  "production": true,
  "pwaTestEnabled": true,
  "routes": [
    { "path": "/", "name": "today" },
    { "path": "/program", "name": "program" },
    { "path": "/discover", "name": "discover" },
    { "path": "/settings", "name": "settings" }
  ],
  "clipPaths": ["/discover", "/program", "/"],
  "scrollQaPath": "/settings",
  "moreButton": ".mobile-tabbar button[aria-label=\"更多\"]",
  "moreClose": ".mobile-more-close"
