{
  "id": "fitness",
  "name": "FITNESS.OS",
  "shortName": "FITNESS",
  "description": {
    "zh": "胸 · 背 · 腿 · 臂 四日循环保练 · 手臂围优先",
    "en": "Four-day split training · arm circumference first"
  },
  "themeColor": { "light": "#f4f4f3", "dark": "#0d0d0e" },
  "defaultTheme": "dark",
  "locale": "zh-CN",
  "storageKey": "fitos_v2",
  "storageKind": "nested",
