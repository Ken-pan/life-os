{
  "name": "fitness-os",
  "version": "3.0.0",
  "description": "FITNESS.OS — 胸·背·手·腿 四日循环训练管理（SvelteKit 重构）",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "pwa:preview": "vite preview -- --host 0.0.0.0 --port 4173",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "check:exercises": "node --import ./scripts/lib/register-alias.mjs scripts/validate-exercises.mjs",
    "check:schemes": "node --import ./scripts/lib/register-alias.mjs scripts/verify-schemes.mjs",
    "check:data": "npm run check:exercises && npm run check:schemes && npm run check:delts",
    "check:delts": "node --import ./scripts/lib/register-alias.mjs scripts/audit-delts.mjs",
    "test:migrate": "node scripts/test-migrate-exercises.mjs",
    "test:sync": "node scripts/test-sync-logic.mjs",
    "test:supabase": "node scripts/test-supabase-connectivity.mjs",
    "test:unit": "npm run test:plates && npm run test:weight-memory && npm run test:deload && npm run test:session-duration && npm run test:rest-policy && npm run test:mcp",
    "test:rest-policy": "node --import ./scripts/lib/register-alias.mjs src/lib/restPolicy.core.test.js",
    "test:mcp": "node server/mcpFitness.test.mjs",
    "test:plates": "node --import ./scripts/lib/register-alias.mjs scripts/plate-calculators-check.mjs",
    "test:weight-memory": "node --import ./scripts/lib/register-alias.mjs scripts/weight-memory-check.mjs",
    "test:deload": "node --import ./scripts/lib/register-alias.mjs scripts/progression-deload-check.mjs",
    "test:session-duration": "node --import ./scripts/lib/register-alias.mjs scripts/session-duration-check.mjs",
    "test": "npm run test:unit && playwright test",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test -c playwright.e2e-ci.config.js",
    "test:e2e:strict": "CI=1 playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "postcss-custom-media": "^12.0.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "vite": "^8.1.0"
  },
  "dependencies": {
    "@life-os/contracts": "*",
    "@life-os/mcp-server": "*",
    "@life-os/platform-web": "*",
    "@life-os/sync": "*",
    "@life-os/theme": "*",
    "@lucide/svelte": "^1.22.0",
    "@supabase/supabase-js": "^2.110.0"
  }
}
