{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HealthOS",
  "version": "0.1.0",
  "identifier": "space.kenos.health",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://127.0.0.1:5192",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "HEALTH.OS",
        "width": 1180,
        "height": 800,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "category": "HealthcareFitness",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
