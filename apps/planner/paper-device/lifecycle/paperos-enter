#!/bin/sh
# paperos-enter — PAPR.SYS.1 managed handoff xochitl -> PaperOS. Idempotent.
#
# Exit codes:
#   0 PaperOS active (fresh launch or already active)
#   2 another lifecycle operation holds the lock
#   3 emergency-disabled (DISABLED marker)
#   4 incompatible OS build (compat.allowed mismatch)
#   5 PaperOS binary missing or not executable
#   6 launch failed, native shell recovered
#   7 launch failed AND native recovery failed (state stays RECOVERY)
set -u

LIFECYCLE_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
. "$LIFECYCLE_DIR/paperos-lib.sh"

ensure_run_dir

if ! acquire_lock lifecycle; then
  log_line enter blocked reason=lock-busy
  echo "paperos-enter: another lifecycle operation is running" >&2
  exit 2
fi
trap 'release_lock lifecycle' EXIT INT TERM HUP

if is_disabled; then
  set_state DISABLED
  log_line enter blocked reason=disabled
  echo "paperos-enter: blocked by DISABLED marker ($DISABLE_MARKER)" >&2
  exit 3
fi

if ! compat_ok; then
  set_state INCOMPATIBLE
  log_line enter blocked reason=incompatible version_id="$(current_version_id)"
  echo "paperos-enter: OS build not in $COMPAT_FILE — fail closed" >&2
  exit 4
fi

if [ ! -x "$PAPEROS_BIN" ]; then
  log_line enter blocked reason=binary-missing bin="$PAPEROS_BIN"
  echo "paperos-enter: PaperOS binary missing or not executable: $PAPEROS_BIN" >&2
  exit 5
fi

# Idempotent: repeated enter while PaperOS is already up is a no-op.
if paperos_ready; then
  set_state PAPEROS_ACTIVE
  log_line enter noop reason=already-active
  exit 0
fi

set_state ENTERING_PAPEROS
log_line enter begin

# paperos.service Conflicts=xochitl.service: systemd stops xochitl (and its
# bound rm-sync) before starting PaperOS. ExecStopPost restores xochitl on
# any unit exit, so even a crash between here and readiness falls back.
if ! systemctl start paperos; then
  log_line enter failed reason=unit-start-failed
  if recover_to_native enter_unit_start_failed; then
    exit 6
  fi
  exit 7
fi

_deadline=$(( $(now_epoch) + READY_TIMEOUT ))
_ready=0
while :; do
  if paperos_ready; then _ready=1; break; fi
  if [ "$(now_epoch)" -ge "$_deadline" ]; then break; fi
  sleep 1
done

# Stability window: a binary that starts and dies instantly must not be
# reported as active.
if [ "$_ready" = 1 ] && [ "$STABLE_SECS" -gt 0 ]; then
  sleep "$STABLE_SECS"
  paperos_ready || _ready=0
fi

if [ "$_ready" != 1 ]; then
  log_line enter failed reason=readiness-timeout timeout="$READY_TIMEOUT"
  if recover_to_native enter_readiness_failed; then
    exit 6
  fi
  exit 7
fi

set_state PAPEROS_ACTIVE
log_line enter done
exit 0
