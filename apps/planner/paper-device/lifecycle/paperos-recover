#!/bin/sh
# paperos-recover — PAPR.SYS.1 emergency return to the native shell.
#
# Device-side only; never depends on the Mac being online. Steals a stuck
# lifecycle lock (this IS the emergency path), stops any crash-loop
# candidate, kills residue, clears stale locks, restores xochitl, and
# verifies xochitl + rm-sync + zero PaperOS processes.
#
# Usage: paperos-recover [reason]
#
# Exit codes: 0 native verified · 1 native NOT verified (state stays RECOVERY)
set -u

LIFECYCLE_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
. "$LIFECYCLE_DIR/paperos-lib.sh"

REASON="${1:-manual}"

ensure_run_dir

# Emergency path: a wedged enter/exit must not block recovery.
rm -rf "$RUN_DIR/lock.lifecycle"
acquire_lock lifecycle || true
trap 'release_lock lifecycle' EXIT INT TERM HUP

if recover_to_native "$REASON"; then
  echo "paperos-recover: native shell verified (xochitl + rm-sync active)"
  exit 0
fi

echo "paperos-recover: native shell NOT verified — inspect $LOG_FILE" >&2
exit 1
