{
  "name": "startup-warm",
  "iterations": 10,
  "setup": [
    "systemctl stop paperos"
  ],
  "actions": [
    { "cmd": "wait", "condition": "page=today", "timeout": 10000 }
  ],
  "metrics": [
    "startup_time",
    "peak_rss"
  ],
  "assertions": [
    { "metric": "startup_time", "max": 4000 }
  ],
  "cleanup": [
    "systemctl stop paperos"
  ],
  "recovery": "recover"
}
