{
  "name": "navigation-core",
  "iterations": 5,
  "setup": [
    "systemctl restart paperos"
  ],
  "actions": [
    { "cmd": "wait", "condition": "page=today", "timeout": 10000 },
    { "cmd": "tap", "id": "nav.write" },
    { "cmd": "wait", "condition": "page=write", "timeout": 2000 },
    { "cmd": "tap", "id": "nav.inbox" },
    { "cmd": "wait", "condition": "page=inbox", "timeout": 2000 },
    { "cmd": "tap", "id": "nav.today" },
    { "cmd": "wait", "condition": "page=today", "timeout": 2000 }
  ],
  "metrics": [
    "route_transition_time"
  ],
  "cleanup": [
    "systemctl stop paperos"
  ],
  "recovery": "recover"
}
