{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "KnowledgeOS",
  "version": "0.1.0",
  "identifier": "space.kenos.knowledge",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://127.0.0.1:5879",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "KnowledgeOS",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["knowledgeos"]
      }
    }
  }
}
