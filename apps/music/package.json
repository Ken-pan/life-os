{
  "name": "music-os",
  "version": "0.1.0",
  "description": "MUSIC.OS — 本地音乐播放器 PWA",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 5189 --strictPort --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview",
    "pwa:preview": "vite preview -- --host 0.0.0.0 --port 5191",
    "preview:static": "npx --yes serve build -s -l 5193",
    "test:sw": "node scripts/qa-service-worker.mjs",
    "test:sw:full": "npm run build && node scripts/qa-service-worker.mjs",
    "qa:ui-flow": "node scripts/qa-ui-flow.mjs",
    "qa:import": "node scripts/qa-import-e2e.mjs",
    "qa:rec-behavior": "node scripts/qa-recommendation-behavior.mjs",
    "test:e2e": "node scripts/qa-ui-flow.mjs",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios",
    "ios:build:sim": "npm run ios:sync && xcodebuild -project ios/App/App.xcodeproj -scheme App -sdk iphonesimulator -destination 'platform=iOS Simulator,name=iPhone 17 Pro' build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "playwright": "^1.61.1",
    "postcss-custom-media": "^12.0.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "vite": "^8.1.0"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@life-os/capacitor-nowplaying": "*",
    "@life-os/contracts": "*",
    "@life-os/platform-web": "*",
    "@life-os/sync": "*",
    "@life-os/theme": "*",
    "@lucide/svelte": "^1.22.0",
    "@supabase/supabase-js": "^2.110.0",
    "dexie": "^4.0.11",
    "svelte-dnd-action": "^0.9.70",
    "tus-js-client": "^4.3.1"
  }
}
